# Compiler files
cache/
out/
out-full/
out-ci/
out-deploy/

# Ignores development broadcast logs
broadcast/
!/broadcast/*/31337/

# Forge auto-generated docs (keep manual docs/)
docs/book/

# Dotenv file
.env

# Coverage
lcov.info
coverage/

# Node modules (if using npm for anything)
node_modules/

# LaTeX build artifacts
*.aux
*.log
*.out
*.synctex.gz
*.fls
*.fdb_latexmk

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
frontend/dist/
frontend/.vercel/
jarvis-bot/webapp/dist/
jarvis-bot/webapp/node_modules/

# Generated document exports (originals stay in docs/*.md)
docs/pdf/

# Jarvis bot runtime data (seeded from repo, but live data stays on Fly volume)
jarvis-bot/data/*.json
!jarvis-bot/data/behavior.json

# Build logs
*.log
__pycache__/
*.egg-info/

.vercel

# TLS certificates (NEVER commit)
*.pem
.cold-wallet

# Working context files (session memory, not for public repo)
.claude/
.session-chain/

# Video files (too large for git)
*.mp4
*.mepj
Video content*/
