# =============================================================================
# VibeSwap — environment variable template
# =============================================================================
# Copy to `.env` and fill in. `.env` is gitignored; `.env.example` is committed.
#
# Many of these are read by Foundry deploy scripts via `vm.envUint`,
# `vm.envAddress`, `vm.envOr`. Only set the ones you need for the script
# you're running. See script/Deploy*.s.sol and script/ConfigurePeers.s.sol
# for which scripts consume which vars.
# =============================================================================


# ---- Deployer ----------------------------------------------------------------
# Private key used by `forge script ... --broadcast`. Hex, WITH 0x prefix.
# NEVER commit a real key. For local Anvil use the default test key prefixed:
#   0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
PRIVATE_KEY=

# Default owner / admin for newly deployed contracts. If unset, deploy
# scripts fall back to the deployer address. For mainnet, set to the multisig.
OWNER_ADDRESS=

# Multisig address (used by governance, compliance, agents deploy paths).
# Some scripts read MULTISIG_ADDRESS, others read MULTISIG — set both
# to the same value to be safe.
MULTISIG_ADDRESS=
MULTISIG=


# ---- RPC URLs ----------------------------------------------------------------
# Mainnet
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Testnets
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ARB_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org


# ---- Block-explorer API keys (for `forge script --verify`) -------------------
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
OPSCAN_API_KEY=
BASESCAN_API_KEY=
POLYGONSCAN_API_KEY=
SNOWTRACE_API_KEY=
BSCSCAN_API_KEY=


# ---- Cross-chain router addresses (filled after deployment) ------------------
# Read by script/ConfigurePeers.s.sol to wire LayerZero V2 peer relationships
# across deployed routers.

# Mainnet
ROUTER_ETHEREUM=
ROUTER_ARBITRUM=
ROUTER_OPTIMISM=
ROUTER_BASE=
ROUTER_POLYGON=
ROUTER_AVALANCHE=
ROUTER_BSC=

# Testnet
ROUTER_SEPOLIA=
ROUTER_ARB_SEPOLIA=
ROUTER_BASE_SEPOLIA=

# Active router for the current chain (used by ConfigurePeers)
ROUTER_ADDRESS=


# ---- Core protocol address registry ------------------------------------------
# Used by downstream deploy scripts (compliance, agents, settlement)
# to wire into an already-deployed core stack.
VIBESWAP_CORE=
FEDERATED_CONSENSUS=
COMPLIANCE_REGISTRY=
CLAWBACK_REGISTRY=
CLAWBACK_VAULT=


# ---- Agents stack (script/DeployAgents.s.sol) --------------------------------
AGENT_PROTOCOL=
AGENT_REPUTATION=
AGENT_MEMORY=
AGENT_PERSISTENCE=
AGENT_NETWORK=
AGENT_CONSENSUS=
TASK_ENGINE=
AGENT_ORCHESTRATOR=

# Tunables
ARBITRATOR=
# Minimum stake required to participate in consensus (wei). Default 0.01 ether.
CONSENSUS_MIN_STAKE=10000000000000000
# PoW difficulty target (uint256). Default = type(uint256).max / 1000.
CONSENSUS_POW_DIFF=


# ---- Frontend / off-chain integrations ---------------------------------------
# X (Twitter) bearer token for @godofprompt feed integration in the frontend.
# Free tier works. Get one at https://developer.twitter.com
X_BEARER_TOKEN=
