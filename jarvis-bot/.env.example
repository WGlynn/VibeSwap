# ============ REQUIRED ============

# Telegram — get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Anthropic — Claude API key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ============ MODEL ============

# claude-opus-4-6 for deep analysis, claude-sonnet-4-5-20250929 for casual
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ============ PATHS (local development) ============
# These are overridden by Docker/entrypoint.sh in cloud mode

VIBESWAP_REPO=/c/Users/Will/vibeswap
MEMORY_DIR=/c/Users/Will/.claude/projects/C--Users-Will/memory
# DATA_DIR defaults to VIBESWAP_REPO/jarvis-bot/data

# ============ DOCKER/CLOUD ============
# Only needed for Docker or cloud deployment

# GitHub personal access token (for cloning private repo in cloud)
# GITHUB_TOKEN=ghp_your_token_here

# Repository URLs (defaults to vibeswap-private)
# GITHUB_REPO_URL=https://github.com/WGlynn/vibeswap-private.git
# GITHUB_STEALTH_URL=https://github.com/WGlynn/vibeswap-private.git

# Health check port (auto-enabled in Docker, set to enable locally)
# HEALTH_PORT=8080

# ============ TELEGRAM IDS ============

# Authorized Telegram user IDs (comma-separated)
AUTHORIZED_USERS=

# Owner (Will) — co-admin with Jarvis, 50/50 governance
OWNER_USER_ID=8366932263

# Bot username (for mention detection)
BOT_USERNAME=JarvisMind1828383bot

# Community group chat ID (use /whoami in group to get it)
COMMUNITY_GROUP_ID=

# The Ark — backup group ID. /ark DMs everyone an invite if main chat dies.
ARK_GROUP_ID=

# ============ GROUP MONITOR (MTProto) ============
# Reads public Telegram groups without joining them.
# Get API credentials from https://my.telegram.org/apps

# TG_API_ID=12345678
# TG_API_HASH=abcdef1234567890abcdef1234567890

# Comma-separated public group usernames to monitor (no @)
MONITORED_GROUPS=NervosNation

# Poll interval in ms (default 10 min)
# MONITOR_POLL_INTERVAL=600000

# ============ CLAUDE CODE BRIDGE ============
# Shared secret for direct HTTP API communication between JARVIS and Claude Code.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same secret in both jarvis-bot/.env and as CLAUDE_CODE_API_SECRET env var.
CLAUDE_CODE_API_SECRET=

# ============ PRIVACY / ENCRYPTION ============
# Master key for encrypting knowledge bases. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, auto-generated on first boot and saved to data/.master-key
# IMPORTANT: Back up this key. Losing it = losing all encrypted knowledge.
JARVIS_MASTER_KEY=
# Set to false to disable encryption (NOT recommended)
# ENCRYPTION_ENABLED=true

# ============ SHARD / NETWORK (Decentralized Mind Network) ============
# Shard identity — unique per instance
SHARD_ID=shard-0
# Total shards in the network (1 = single instance, same as current)
TOTAL_SHARDS=1
# Node type: 'light' (prune aggressively), 'full' (retain history, storage discount),
# 'archive' (pure storage, no processing, min 3 for network survival)
NODE_TYPE=full
# State backend: 'file' (default, backward compatible) or 'redis' (Phase 2)
STATE_BACKEND=file
# Redis URL — required if STATE_BACKEND=redis
# REDIS_URL=redis://localhost:6379
# Router URL — required for multi-shard routing (Phase 2)
# ROUTER_URL=http://router:8090

# ============ GIT ============

GIT_REMOTE_ORIGIN=origin
GIT_REMOTE_STEALTH=stealth

# ============ INTERVALS ============

# Auto-sync: pull from git + reload context (ms, default 10s)
AUTO_SYNC_INTERVAL=10000

# Auto-backup: commit data/ to git (ms, default 30min)
AUTO_BACKUP_INTERVAL=1800000

# Daily digest: UTC hour to send (0-23, default 18 = 6pm UTC)
DIGEST_HOUR=18

# Rate limit: max Claude API calls per user per minute (owner exempt)
RATE_LIMIT_PER_MINUTE=5
