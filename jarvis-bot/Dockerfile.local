# ============================================================
# Jarvis Local Inference Shard — Zero API Dependency
# ============================================================
# Runs Ollama + Jarvis in the same container.
# No external API calls needed. Self-hosted mind.
#
# Build: docker build -f Dockerfile.local -t jarvis-local .
# Run:   docker run -p 8080:8080 -v ollama_data:/root/.ollama jarvis-local
# ============================================================

# Stage 1: Build Mini App
FROM node:20-slim AS webapp-build
WORKDIR /build
COPY webapp/package.json webapp/package-lock.json* ./
RUN npm ci 2>/dev/null || npm install
COPY webapp/ ./
RUN npm run build

# Stage 2: Runtime with Ollama
FROM node:20-slim

# Install git, curl, and Ollama
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates curl \
    fonts-noto-core fonts-noto-mono fontconfig \
    && curl -fsSL https://ollama.com/install.sh | sh \
    && apt-get clean && rm -rf /var/lib/apt/lists/* \
    && fc-cache -fv

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Copy source
COPY src/ ./src/

# Copy built Mini App
COPY --from=webapp-build /build/dist ./webapp/dist/

# Bundle memory files
COPY memory/ /app/memory/

# Bundle core context fallback
COPY context-fallback/ /app/context-fallback/

# Data directory
RUN mkdir -p /app/data

# Entrypoint: start Ollama, pull model, then start Jarvis
COPY <<'ENTRYPOINT' /app/entrypoint-local.sh
#!/bin/bash
set -e

echo "============================================"
echo "JARVIS LOCAL INFERENCE SHARD"
echo "No API key. No rate limit. No toll booth."
echo "============================================"

# Start Ollama in background
echo "[local] Starting Ollama server..."
ollama serve &

# Wait for Ollama
for i in $(seq 1 30); do
  if curl -sf http://localhost:11434/api/tags > /dev/null 2>&1; then
    echo "[local] Ollama ready (${i}s)"
    break
  fi
  sleep 1
done

# Pull model (cached on persistent volume after first pull)
MODEL="${OLLAMA_MODEL:-qwen2.5:7b}"
echo "[local] Ensuring model: ${MODEL}"

if ollama list 2>/dev/null | grep -q "${MODEL}"; then
  echo "[local] Model ${MODEL} already cached"
else
  echo "[local] Pulling ${MODEL} (first run only)..."
  ollama pull "${MODEL}"
fi

# Pre-warm: load model into RAM
echo "[local] Pre-warming model..."
curl -sf http://localhost:11434/api/chat -d "{\"model\":\"${MODEL}\",\"messages\":[{\"role\":\"user\",\"content\":\"hello\"}],\"stream\":false}" > /dev/null 2>&1 || true
echo "[local] Model warm and ready"

# Start Jarvis
echo "[local] Starting Jarvis shard..."
exec node --expose-gc --max-old-space-size=512 src/index.js
ENTRYPOINT

RUN chmod +x /app/entrypoint-local.sh

EXPOSE 8080

ENTRYPOINT ["/app/entrypoint-local.sh"]
