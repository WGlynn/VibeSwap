# ============ JARVIS VPS Environment ============
# Copy to .env and fill in your secrets.
# Used with: docker compose -f docker-compose.vps.yml up -d

# ============ REQUIRED ============

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# GitHub PAT for private repo clone (needs 'repo' scope)
GITHUB_TOKEN=

# ============ LLM PROVIDERS ============
# VPS stack uses Groq (free 14K req/day) as primary,
# Ollama (local, zero cost) as fallback,
# plus whatever API keys you add for the Wardenclyffe cascade.

# Primary provider (groq recommended for free tier speed)
LLM_PROVIDER=groq
GROQ_API_KEY=

# Cheap API fallbacks
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=

# Premium fallbacks (optional — add if you have keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# Local model (runs on Ollama container, shared between shards)
# Default: qwen2.5:7b (~4.7GB, good balance of quality/speed on CX31)
# Alternatives: qwen2.5:3b (lighter), llama3.1:8b, mistral:7b
LLM_MODEL=qwen2.5:7b

# ============ TELEGRAM ============
OWNER_USER_ID=8366932263
BOT_USERNAME=JarvisMind1828383bot
COMMUNITY_GROUP_ID=
ARK_GROUP_ID=
AUTHORIZED_USERS=

# ============ GIT ============
GITHUB_REPO_URL=https://github.com/WGlynn/vibeswap-private.git
GITHUB_STEALTH_URL=

# ============ NETWORK ============
TOTAL_SHARDS=2
SHARD_SECRET=

# ============ SECURITY ============
JARVIS_MASTER_KEY=
ENCRYPTION_ENABLED=true

# ============ WEB ============
WEB_CORS_ORIGINS=https://frontend-jade-five-87.vercel.app,http://localhost:3000
CLAUDE_CODE_API_SECRET=

# ============ MONITORING (optional) ============
MONITORED_GROUPS=
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=

# ============ DOMAIN (optional — for Let's Encrypt SSL) ============
# Set this before running vps-deploy.sh for automatic HTTPS
# JARVIS_DOMAIN=jarvis.yourdomain.com
